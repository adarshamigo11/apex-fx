# Production Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to GitHub!

# Backend API URL (Railway will provide this)
# Format: https://your-app.railway.app
NEXT_PUBLIC_API_URL=https://your-backend.railway.app/api

# WebSocket URL (Railway will provide this)
# Format: wss://your-app.railway.app
NEXT_PUBLIC_WS_URL=wss://your-backend.railway.app

# Optional: App name for branding
NEXT_PUBLIC_APP_NAME=ApexFX

# Optional: Analytics (if using)
# NEXT_PUBLIC_GA_ID=<google-analytics-id>
