{
  "name": "forex-paper-backend",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "seed": "tsx src/scripts/seed.ts",
    "typecheck": "tsc --noEmit",
    "test:engine": "tsx src/scripts/test-engine.ts",
    "test:http": "tsx src/scripts/test-http.ts",
    "test:integration": "tsx src/scripts/test-integration.ts",
    "test": "npm run test:engine && npm run test:http && npm run test:otp",
    "test:otp": "tsx src/scripts/test-otp.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.8.0",
    "nodemailer": "^6.9.14",
    "redis": "^4.7.0",
    "socket.io": "^4.7.5",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/ws": "^8.18.1",
    "mongodb-memory-server": "^11.2.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
